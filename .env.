# Copy this to .env.local and fill in your values
# For Cloudflare Workers, use wrangler secrets commands:
# wrangler secret put BOT_TOKEN
# wrangler secret put OXAPAY_API_KEY
# etc.

BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_admin_telegram_id_here
OXAPAY_API_KEY=your_oxapay_api_key_here
OXAPAY_BASE_URL=https://api.oxapay.com

# Pricing and rewards
GTC_PRICE_USDT=0.1
PRESALE_GTC_REWARD=5000
PRESALE_PRICE_USDT=0.05
TGE_PRICE_USDT=0.2
TGE_WITHDRAWAL_PERCENT=50
PRESALE_WITHDRAWAL_PERCENT=75

# Configuration
DEFAULT_REFER_AMOUNT=100
DEFAULT_MINE_AMOUNT=1000
DEFAULT_MIN_WITHDRAWAL=5000
DEFAULT_MINE_COOLDOWN=86400

# Required channels (JSON format)
REQUIRED_CHANNELS=[{"name":"Channel 1","url":"https://t.me/channel1","tg_id":-1001234567890,"verifiable":true},{"name":"Channel 2","url":"https://t.me/channel2","tg_id":-1001234567890,"verifiable":true}]

# Webhook configuration
WEBHOOK_PATH=/api/telegram
WEBHOOK_SECRET=your_webhook_secret_here
