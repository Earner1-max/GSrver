{
  "name": "telegram-bot-cloudflare",
  "version": "1.0.0",
  "description": "Telegram bot running on Cloudflare Workers with D1 database",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create telegram-bot-db",
    "db:execute": "wrangler d1 execute telegram-bot-db --file=./schema.sql"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "axios": "^1.6.7",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "wrangler": "^3.55.0"
  }
}
